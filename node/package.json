{
  "name": "fsmanifest",
  "version": "0.1.0",
  "description": "TypeScript API for loading, validating, and resolving fsman manifests",
  "author": {
    "name": "Alex Spinu",
    "email": "spinualexandru@outlook.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/spinualexandru/filesystem-selection-manifest#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/spinualexandru/filesystem-selection-manifest.git",
    "directory": "node"
  },
  "bugs": {
    "url": "https://github.com/spinualexandru/filesystem-selection-manifest/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/index.d.ts",
    "dist/index.js",
    "native.cjs",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build:native && npm run build:typescript",
    "build:native": "npm run clean:native && cargo build -p fsman-node --message-format=json-render-diagnostics | neon dist -n fsman-node -d",
    "build:native:release": "npm run clean:native && cargo build --release -p fsman-node --message-format=json-render-diagnostics | neon dist -n fsman-node -d",
    "build:typescript": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "clean:native": "node -e \"require('node:fs').rmSync('index.node', { force: true })\"",
    "platforms:update": "neon update",
    "prepack": "npm run build:typescript",
    "prepublishOnly": "npm run check && npm test",
    "test": "npm run build && node dist/index.test.js"
  },
  "keywords": [
    "fsman",
    "filesystem",
    "manifest",
    "dotfiles",
    "typescript"
  ],
  "devDependencies": {
    "@neon-rs/cli": "^0.2.6",
    "@types/node": "^22.20.1",
    "typescript": "^5.8.3"
  },
  "optionalDependencies": {
    "@spinualexandru/fsmanifest-darwin-arm64": "0.1.0",
    "@spinualexandru/fsmanifest-darwin-x64": "0.1.0",
    "@spinualexandru/fsmanifest-linux-arm64-gnu": "0.1.0",
    "@spinualexandru/fsmanifest-linux-x64-gnu": "0.1.0",
    "@spinualexandru/fsmanifest-win32-x64-msvc": "0.1.0"
  },
  "neon": {
    "type": "library",
    "org": "@spinualexandru",
    "prefix": "fsmanifest-",
    "platforms": "desktop",
    "load": "native.cjs"
  }
}
